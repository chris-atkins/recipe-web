{
  "name": "recipe",
  "private": true,
  "version": "0.0.0",
  "description": "A simple application that stores recipes",
  "repository": "https://github.com/angular/angular-seed",
  "license": "MIT",
  "dependencies": {
    "@angular/common": "^18.2.14",
    "@angular/compiler": "^18.2.14",
    "@angular/core": "^18.2.14",
    "@angular/forms": "^18.2.14",
    "@angular/platform-browser": "^18.2.14",
    "@angular/platform-browser-dynamic": "^18.2.14",
    "@angular/router": "^18.2.14",
    "bluebird": "^3.5.3",
    "body-parser": "^1.20.3",
    "bootstrap": "^4.0.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "express-jwt": "^8.5.1",
    "font-awesome": "^4.7.0",
    "form-data": "^4.0.1",
    "jquery": "^3.3.1",
    "jsonwebtoken": "^9.0.2",
    "multiparty": "^4.2.3",
    "ngx-image-cropper": "^9.1.6",
    "ngx-quill": "^26.0.10",
    "passport": "^0.7.0",
    "passport-google-oauth": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "quill": "^2.0.3",
    "request": "^2.88.2",
    "request-promise": "^4.2.6",
    "rxjs": "^7.8.2",
    "zone.js": "^0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "underscore": "^1.8.3",
    "@angular/cli": "^18.2.21",
    "@types/jasmine": "^5.1.13",
    "chromedriver": "^143.0.3",
    "concurrently": "^9.2.1",
    "continuation-local-storage": "^3.2.1",
    "cypress": "^14.5.4",
    "geckodriver": "^4.5.1",
    "http-server": "^14.1.1",
    "jasmine-core": "^3.3.0",
    "jasmine-jquery": "^2.1.1",
    "jshint": "^2.13.6",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-firefox-launcher": "^2.1.3",
    "karma-jasmine": "^4.0.2",
    "karma-jasmine-html-reporter": "^1.7.0",
    "karma-junit-reporter": "^2.0.1",
    "karma-ng-html2js-preprocessor": "^1.0.0",
    "karma-phantomjs-launcher": "^1.0.4",
    "phantomjs-prebuilt": "^2.1.16",
    "protractor": "^7.0.0",
    "shelljs": "^0.8.5",
    "typescript": "~5.4.0"
  },
  "scripts": {
    "ng": "ng",
    "prestart": "npm install",
    "start": "node node-app.js",
    "start:ng": "ng serve --proxy-config proxy.conf.json --port 4200",
    "start:all": "concurrently \"npm run start\" \"npm run start:ng\"",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "cypress": "cypress open",
    "cypress:headless": "cypress run",
    "pretest": "npm install",
    "test": "karma start karma.conf.js",
    "test:ng": "ng test",
    "test:ngjs": "karma start karma.conf.js",
    "test-single-run": "npm install && karma start karma.conf.js --single-run",
    "pretest-headless": "npm install",
    "test-headless": "karma start karma-headless.conf.js --single-run",
    "lint": "jshint e2e-tests/*.js e2e-tests/**/*.js node-app.js",
    "posttest-headless": "npm run lint",
    "preupdate-webdriver": "npm install",
    "update-webdriver": "webdriver-manager update",
    "preprotractor": "npm run update-webdriver",
    "protractor": "protractor e2e-tests/protractor.conf.js",
    "prejenkins-protractor": "npm run update-webdriver",
    "jenkins-protractor": "protractor e2e-tests/ci.protractor.conf.js",
    "prod-protractor": "npm run update-webdriver && protractor prod-monitoring/prod.monitoring.protractor.conf.js",
    "presingle-file-e2e": "./start-test-servers.sh",
    "single-file-e2e": "protractor e2e-tests/protractor.conf.js --specs=e2e-tests/login-spec.js",
    "allTests": "npm run lint && npm run test-single-run && npm run protractor"
  }
}
